{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).wasm",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-blobs",
      "schedule": "0 */6 * * *"
    }
  ]
}
